# ai-service 환경변수 예시 (실제 값은 .env 파일에 작성, 절대 커밋 금지)

NODE_ENV=development
PORT=3001

# Perplexity API - 자동 뉴스 수집
# 발급: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Claude API - 뉴스 분류/요약
# 발급: https://console.anthropic.com
CLAUDE_API_KEY=

# 카카오 REST API - 개인 메시지 발송 (나에게 보내기 memo API)
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키
KAKAO_REST_API_KEY=
# 카카오 액세스 토큰 (OAuth2 발급 — 6시간 유효, 만료 시 refresh_token으로 갱신)
# 발급 방법: docs/deploy/n8n-cloud-guide.md 참고
KAKAO_ACCESS_TOKEN=

# api-server 연동 보안
# 생성: openssl rand -hex 32
INTERNAL_API_SECRET=
API_SERVER_URL=http://localhost:8080

# CORS 허용 origin (쉼표 구분, 기본값: http://localhost:3000)
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Redis (중복 방지 캐시)
# 로컬: REDIS_HOST/PORT 사용, 프로덕션(Railway): REDIS_URL 사용
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379  ← Railway 배포 시 이 형식으로 환경변수 주입됨
