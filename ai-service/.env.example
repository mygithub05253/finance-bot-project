# ai-service 환경변수 예시 (실제 값은 .env 파일에 작성, 절대 커밋 금지)

NODE_ENV=development
PORT=3001

# Perplexity API - 자동 뉴스 수집
# 발급: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Claude API - 뉴스 분류/요약
# 발급: https://console.anthropic.com
CLAUDE_API_KEY=

# 카카오 REST API - 개인 메시지 발송
# 발급: https://developers.kakao.com
KAKAO_REST_API_KEY=
# 본인 카카오 UUID (나에게 보내기)
# 발급 방법: .claude/security.md 참조
KAKAO_TARGET_UUID=

# api-server 연동 보안
# 생성: openssl rand -hex 32
INTERNAL_API_SECRET=
API_SERVER_URL=http://localhost:8080

# Redis (중복 방지 캐시)
REDIS_HOST=localhost
REDIS_PORT=6379
